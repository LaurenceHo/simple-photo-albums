    "@vue/tsconfig": "0.9.1",
    "embla-carousel": "^8.6.0",
    "eslint": "10.2.0",
    "eslint-plugin-vue": "^10.8.0",
    "jsdom": "29.0.2",
    "msw": "^2.13.3",
    "prettier": "^3.8.3",
