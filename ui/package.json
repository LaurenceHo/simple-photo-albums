    "exifreader": "^4.38.1",
    "mapbox-gl": "^3.21.0",
    "pinia": "^3.0.4",
    "primevue": "^4.5.5",
    "radash": "^12.1.1",
    "tailwindcss": "^4.2.2",
    "tailwindcss-primeui": "0.6.1",
    "vue": "^3.5.32",
    "vue-router": "5.0.4",
    "zod": "4.3.6"
